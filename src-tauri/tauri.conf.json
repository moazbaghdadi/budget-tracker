{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Budget Tracker",
  "version": "0.1.0",
  "identifier": "com.moazbaghdadi.budget-tracker",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "متتبع الميزانية",
        "width": 1280,
        "height": 820,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm", "dmg", "app", "msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Finance",
    "shortDescription": "متتبع ميزانية بسيط للشركات الصغيرة",
    "longDescription": "تطبيق سطح مكتب لتتبع الدخل والمصروفات، مع حفظ على القرص وسجل تراجع متفرع."
  },
  "plugins": {
    "fs": {
      "scope": ["$APPCONFIG/budget-tracker/*"],
      "requireLiteralLeadingDot": false
    }
  }
}
